# ============================================================
# AI技术趋势雷达 - 亚马逊云侧环境变量
# 复制为 .env 并填入实际值
# 文件权限: chmod 600 .env
# ============================================================

# 外部大模型 API Key（OpenAI）
OPENAI_API_KEY=sk-xxx

# 外部大模型 API Key（Anthropic Claude）- 可选
ANTHROPIC_API_KEY=

# 外部大模型 API Key（Google Gemini）- 可选
GOOGLE_API_KEY=

# 仅 hybrid/search 模式的外部搜索补充使用；默认 site 模式必须留空
SEARCH_API_KEY=

# Playwright Chromium 固定安装目录，需与 systemd 配置一致
PLAYWRIGHT_BROWSERS_PATH=/app/001804/aws/.playwright-browsers
# 可选：不下载 Playwright Chromium 时，指向系统 Chromium/Chrome/Edge。
# Linux 示例：/usr/bin/chromium；Windows 示例：C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
PLAYWRIGHT_BROWSER_EXECUTABLE_PATH=

# 内部受控导入接口地址
IMPORT_ENDPOINT_URL=http://168.64.18.190:9001/api/v1/radar/import

# 服务端口
AI_RADAR_PORT=9003

# 配置目录（非默认时设置）
AI_RADAR_CONFIG_DIR=/app/001804/aws/config
